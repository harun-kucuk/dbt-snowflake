# Copy this file to airflow/.env and fill in your values.
# Never commit airflow/.env — it contains credentials.

# Snowflake credentials (same vars used by dbt/profiles.yml)
SNOWFLAKE_ACCOUNT=your_account.snowflakecomputing.com
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=your_warehouse

# Airflow fernet key — used to encrypt the Snowflake connection password in the metadata DB.
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Never change this after first run — rotating it decrypts existing stored passwords.
AIRFLOW__CORE__FERNET_KEY=
