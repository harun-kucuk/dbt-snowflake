# Snowflake connection settings
# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

SNOWFLAKE_ACCOUNT=your_account.region        # e.g. xy12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=your_role                     # set explicitly; no default role is assumed
SNOWFLAKE_DATABASE=dev_yourname     # dev → dev_<user> (defaults to dev_$SNOWFLAKE_USER) | ci → CI_<pr> (set dynamically) | prod → ANALYTICS (hardcoded in profiles.yml)
SNOWFLAKE_WAREHOUSE=TRANSFORMING
SNOWFLAKE_SCHEMA=dev_yourname                # personal dev schema, e.g. dev_jdoe
