# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Root tfvars contains password — never commit
terraform.tfvars

# Environment tfvars (no secrets — committed)
!envs/*.tfvars
!*.tfvars.example

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
